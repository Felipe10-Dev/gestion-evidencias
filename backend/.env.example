PORT=3000
TRUST_PROXY=true

# Option 1 (recommended in Railway): full Postgres URL
# DATABASE_URL=postgresql://user:password@host:5432/database

# Option 2: explicit fields
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gestion_evidencias
DB_USER=postgres
DB_PASSWORD=change_me

# Use SSL in production/managed DBs like Railway
DB_SSL=false

# Schema management
# - DB_RUN_MIGRATIONS: runs additive-only migrations at startup (recommended)
# - DB_SYNC_ALTER: when true, Sequelize will auto-alter tables to match models (NOT recommended in production)
DB_RUN_MIGRATIONS=true
DB_SYNC_ALTER=false

# For local development only (optional):
# DB_SYNC_ALTER=true

# Google Drive auth mode:
# - auto: tries OAuth first, then Service Account
# - oauth: only OAuth variables
# - service_account: only Service Account (env JSON or file)
GOOGLE_DRIVE_AUTH_MODE=auto

# Service Account credentials (recommended for Railway/Render/etc).
# Can be the JSON content directly or a base64-encoded JSON.
GOOGLE_DRIVE_CREDENTIALS_JSON=

# Path to Google Service Account JSON key file
GOOGLE_DRIVE_CREDENTIALS_PATH=./google-service-account.json

# Optional default folder for uploads when team has no drive_folder_id
GOOGLE_DRIVE_FOLDER_ID=

# Optional OAuth2 credentials for uploading to your own Google Drive account.
# Required when GOOGLE_DRIVE_AUTH_MODE=oauth.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Redirect URI used to generate refresh tokens locally.
# Ensure it is registered in Google Cloud Console for your OAuth client.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/oauth2callback
