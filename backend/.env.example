PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=gestion_evidencias
DB_USER=postgres
DB_PASSWORD=admin123

# Path to Google Service Account JSON key file
GOOGLE_DRIVE_CREDENTIALS_PATH=./google-service-account.json

# Optional default folder for uploads when team has no drive_folder_id
GOOGLE_DRIVE_FOLDER_ID=

# Optional OAuth2 credentials for uploading to your own Google Drive account.
# If these are set, they take priority over the service account JSON.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
